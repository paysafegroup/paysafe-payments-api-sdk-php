{
  "name": "paysafe/paymentsapi-sdk-php",
  "description": "Paysafe Payments API SDK for PHP",
  "type": "library",
  "license": "MIT",
  "require": {
    "php": ">=7.4.0",
    "ext-curl": "*",
    "ext-json": "*",
    "guzzlehttp/guzzle": "^7.9",
    "symfony/serializer": "^5.4",
    "symfony/property-access": "^5.4",
    "phpdocumentor/reflection-docblock": "^5.6",
    "monolog/monolog": "^2.0 || ^3.0"
  },
  "autoload": {
    "psr-4": {
      "Paysafe\\PhpSdk\\": "src/"
    }
  },
  "require-dev": {
    "phpunit/phpunit": "^9.6"
  }
}
